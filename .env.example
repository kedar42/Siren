# Discord
DISCORD_TOKEN=
# Comma-separated guild IDs you want this bot in (enables instant slash command sync).
DISCORD_GUILD_IDS=

# Spotify — register a free app at https://developer.spotify.com/dashboard
# Used for metadata resolution only; audio still streams from YouTube.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional. Path inside the container to a Netscape-format cookies.txt
# (e.g. /app/data/cookies.txt) for yt-dlp. Set this only if YouTube starts
# blocking with "Sign in to confirm you're not a bot".
YT_COOKIES_FILE=

# DEBUG for verbose stage-by-stage logs.
LOG_LEVEL=INFO
